{
    "name": "cywolf/semantic-suggestion-solr",
    "type": "typo3-cms-extension",
    "description": "TYPO3 extension for suggesting semantically related content using Solr More Like This (MLT) and Semantic More Like This (SMLT)",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "typo3",
        "solr",
        "more-like-this",
        "mlt",
        "semantic-search",
        "vector-search",
        "knn",
        "recommendations",
        "related-content",
        "tx-news"
    ],
    "homepage": "https://github.com/friteuseb/semantic_suggestion_solr",
    "support": {
        "issues": "https://github.com/friteuseb/semantic_suggestion_solr/issues",
        "source": "https://github.com/friteuseb/semantic_suggestion_solr"
    },
    "authors": [
        {
            "name": "Cyril Wolfangel",
            "email": "cyril.wolfangel@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "typo3/cms-core": "^13.4",
        "typo3/cms-extbase": "^13.4",
        "typo3/cms-fluid": "^13.4",
        "apache-solr-for-typo3/solr": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Cywolf\\SemanticSuggestionSolr\\": "Classes/"
        }
    },
    "extra": {
        "typo3/cms": {
            "extension-key": "semantic_suggestion_solr"
        }
    },
    "config": {
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    }
}
